{
  "name": "md-explorer",
  "displayName": "Markdown Explorer",
  "description": "Sidebar file explorer for markdown files across /workspace and /home/dev",
  "version": "0.4.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "md-explorer",
          "title": "Markdown Explorer",
          "icon": "$(markdown)"
        }
      ]
    },
    "views": {
      "md-explorer": [
        {
          "id": "mdExplorerFiles",
          "name": "Markdown Files"
        },
        {
          "id": "mdExplorerBacklinks",
          "name": "Backlinks",
          "when": "mdExplorer.hasBacklinksTarget"
        }
      ]
    },
    "commands": [
      {
        "command": "mdExplorer.refresh",
        "title": "Refresh",
        "icon": "$(refresh)",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.toggleMdOnly",
        "title": "Toggle: Show All Files / Markdown Only",
        "icon": "$(filter)",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.newFile",
        "title": "New Markdown File",
        "icon": "$(new-file)",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.newFolder",
        "title": "New Folder",
        "icon": "$(new-folder)",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.rename",
        "title": "Rename",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.delete",
        "title": "Delete",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.revealInExplorer",
        "title": "Reveal in File Explorer",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.copyRelativePath",
        "title": "Copy Relative Path",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.openFile",
        "title": "Open File",
        "category": "Markdown Explorer"
      },
      {
        "command": "mdExplorer.refreshBacklinks",
        "title": "Refresh Backlinks",
        "icon": "$(refresh)",
        "category": "Markdown Explorer"
      }
    ],
    "customEditors": [
      {
        "viewType": "mdExplorer.markdownEditor",
        "displayName": "Markdown Rich Editor",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "default"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "mdExplorer.refreshBacklinks",
          "when": "view == mdExplorerBacklinks",
          "group": "navigation@1"
        },
        {
          "command": "mdExplorer.newFile",
          "when": "view == mdExplorerFiles",
          "group": "navigation@1"
        },
        {
          "command": "mdExplorer.newFolder",
          "when": "view == mdExplorerFiles",
          "group": "navigation@2"
        },
        {
          "command": "mdExplorer.toggleMdOnly",
          "when": "view == mdExplorerFiles",
          "group": "navigation@3"
        },
        {
          "command": "mdExplorer.refresh",
          "when": "view == mdExplorerFiles",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "mdExplorer.newFile",
          "when": "view == mdExplorerFiles && viewItem == folder",
          "group": "1_new@1"
        },
        {
          "command": "mdExplorer.newFolder",
          "when": "view == mdExplorerFiles && viewItem == folder",
          "group": "1_new@2"
        },
        {
          "command": "mdExplorer.rename",
          "when": "view == mdExplorerFiles && viewItem =~ /^(folder|file|mdFile)$/",
          "group": "2_edit@1"
        },
        {
          "command": "mdExplorer.delete",
          "when": "view == mdExplorerFiles && viewItem =~ /^(folder|file|mdFile)$/",
          "group": "2_edit@2"
        },
        {
          "command": "mdExplorer.copyRelativePath",
          "when": "view == mdExplorerFiles && viewItem =~ /^(folder|file|mdFile)$/",
          "group": "3_copy@1"
        },
        {
          "command": "mdExplorer.revealInExplorer",
          "when": "view == mdExplorerFiles && viewItem =~ /^(folder|file|mdFile)$/",
          "group": "4_reveal@1"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./ && node esbuild.config.mjs",
    "watch": "tsc -watch -p ./",
    "build:webview": "node esbuild.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepackage": "npm test",
    "package": "npx @vscode/vsce package --no-dependencies -o dist/",
    "reinstall": "npm run package && code --install-extension dist/md-explorer-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/katex": "^0.16.8",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.0",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@atlaskit/drag-and-drop-indicator": "^0.11.1",
    "@atlaskit/pragmatic-drag-and-drop": "^1.7.9",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/react": "^0.27.19",
    "@lexical/clipboard": "^0.42.0",
    "@lexical/code": "^0.42.0",
    "@lexical/code-prism": "^0.42.0",
    "@lexical/code-shiki": "^0.42.0",
    "@lexical/extension": "^0.42.0",
    "@lexical/file": "^0.42.0",
    "@lexical/hashtag": "^0.42.0",
    "@lexical/history": "^0.42.0",
    "@lexical/link": "^0.42.0",
    "@lexical/list": "^0.42.0",
    "@lexical/mark": "^0.42.0",
    "@lexical/markdown": "^0.42.0",
    "@lexical/overflow": "^0.42.0",
    "@lexical/plain-text": "^0.42.0",
    "@lexical/react": "^0.42.0",
    "@lexical/rich-text": "^0.42.0",
    "@lexical/selection": "^0.42.0",
    "@lexical/table": "^0.42.0",
    "@lexical/text": "^0.42.0",
    "@lexical/utils": "^0.42.0",
    "@prettier/sync": "^0.6.1",
    "date-fns": "^4.1.0",
    "diff": "^8.0.4",
    "katex": "^0.16.40",
    "lexical": "^0.42.0",
    "lodash-es": "^4.17.23",
    "prettier": "^3.8.1",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-error-boundary": "^6.1.1",
    "yjs": "^13.6.30"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ksizzle88/md-explorer.git"
  }
}
